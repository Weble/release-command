{
    "name": "weble/release-command",
    "description": "Laravel Release command using git flow",
    "keywords": [
        "laravel",
        "release-command",
        "release",
        "git-flow",
        "flow"
    ],
    "homepage": "https://github.com/weble/release-command",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniele Rosario",
            "email": "daniele@weble.it",
            "role": "CTO"
        }
    ],
    "require": {
        "php": "^8.1",
        "composer/semver": "^3.4",
        "illuminate/contracts": "^10.0||^11.0||^12.0||^13.0",
        "illuminate/support": "^10.0||^11.0||^12.0||^13.0",
        "laravel/prompts": "^0.3",
        "nunomaduro/laravel-console-task": "v1.11",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "laravel/pint": "^v1.29",
        "nunomaduro/collision": "^8.1.1||^7.10.0",
        "larastan/larastan": "^2.9||^3.0",
        "orchestra/testbench": "^11.0||^10.0.0||^9.0.0||^8.22.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.3||^2.0",
        "phpstan/phpstan-deprecation-rules": "^1.1||^2.0",
        "phpstan/phpstan-phpunit": "^1.3||^2.0"
    },
    "autoload": {
        "psr-4": {
            "Weble\\ReleaseCommand\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Weble\\ReleaseCommand\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Weble\\ReleaseCommand\\ReleaseCommandServiceProvider"
            ],
            "aliases": {
                "ReleaseCommand": "Weble\\ReleaseCommand\\Facades\\ReleaseCommand"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
